@model VulnApp.Models.LoginViewModel
@{
    ViewData["Title"] = "Admin Access";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@* VulnApp v1.0.2 | sl.html — Admin Authentication Module *@
@* VULNERABILITY #1 + #10: Hardcoded credentials in comment *@
@* Admin credentials: admin / SuperSecret@123 *@
@* Backdoor: backdoor_admin / b@ckd00r!2024 *@
@* VULNERABILITY #2: Internal admin endpoint in comment *@
@* Internal admin dashboard: http://192.168.1.105:5000/Admin/AdminPanel *@

@section NavLinks {
  <span style="color:var(--accent2); font-size:0.75rem; font-family:'Share Tech Mono',monospace;">
    ⚠ RESTRICTED AREA
  </span>
}

<div class="page-container" style="background: radial-gradient(ellipse at center, #0d0a1a 0%, #0a0e1a 100%);">
  <div class="card">

    @* VULNERABILITY #10: Security by obscurity noted in comment *@
    @* This page is not linked anywhere — relies on obscurity for discovery prevention *@
    @* Discoverable via: robots.txt, sitemap, forced browsing, directory enumeration *@
    @* VULNERABILITY #4: Token generation uses System.Random (not cryptographically secure) *@
    @* Token space: only 900,000 possible values — easily brute-forceable *@

    <div style="text-align:center; margin-bottom:1.5rem;">
      <div style="font-size:2.5rem; margin-bottom:0.5rem;">🔐</div>
      <h2>Admin Access</h2>
      <p class="subtitle" style="color:var(--accent2);">// restricted — authorised personnel only</p>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
      <div class="alert alert-error">@Model.ErrorMessage</div>
    }

    <form method="post" action="/sl.html">
      <div class="form-group">
        <label for="Username">Admin Username</label>
        <input type="text" id="Username" name="Username" class="form-control"
               placeholder="admin" autocomplete="off" />
      </div>
      <div class="form-group">
        <label for="Password">Admin Password</label>
        <input type="password" id="Password" name="Password" class="form-control"
               placeholder="••••••••••••" />
      </div>
      <button type="submit" class="btn btn-danger">Access Admin Panel</button>
    </form>

    <hr class="divider" />
    <p style="font-size:0.72rem; color:var(--text-muted); text-align:center; font-family:'Share Tech Mono',monospace;">
      @* VULNERABILITY #2: Internal IP in rendered comment *@
      @* Unauthorised access attempts logged to 192.168.1.105/logs/admin_access.log *@
      Unauthorised access attempts are monitored.
    </p>
  </div>
</div>
