@model VulnApp.Models.LoginViewModel
@{
    ViewData["Title"] = "Sign In";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@* VulnApp v1.0.2 | index.html — Sign In Page *@
@* VULNERABILITY #10: SQL injection hint in comment *@
@* Login query: SELECT * FROM users WHERE username='INPUT' AND password='INPUT' *@
@* Try: admin' -- to bypass authentication *@

@section NavLinks {
  <a href="/signup.html">Register</a>
}

<div class="page-container">
  <div class="card">
    <h2>Sign In</h2>
    <p class="subtitle">// access your account</p>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
      <div class="alert alert-error">@Model.ErrorMessage</div>
    }

    @* VULNERABILITY #10: Hardcoded test credentials revealed in HTML comment *@
    @* Test accounts: testuser/password123 | admin/admin123 *@
    @* Admin secret page: /sl.html *@

    <form method="post" action="/">
      <div class="form-group">
        <label for="Username">Username</label>
        <input type="text" id="Username" name="Username" class="form-control"
               placeholder="Enter username" autocomplete="off" />
      </div>
      <div class="form-group">
        <label for="Password">Password</label>
        <input type="password" id="Password" name="Password" class="form-control"
               placeholder="Enter password" />
      </div>
      <button type="submit" class="btn btn-primary">Sign In</button>
    </form>

    <hr class="divider" />
    <p style="font-size:0.82rem; color:var(--text-muted); text-align:center;">
      Don't have an account?
      <a href="/signup.html" style="color:var(--accent);">Create one</a>
    </p>
  </div>
</div>
